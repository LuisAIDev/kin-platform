# ============================================================
# KIN Platform — Environment variables reference
# ============================================================
# Copia este archivo como .env y completa los valores reales.
# ¡NUNCA subas .env a GitHub!

# JWT — Firma de tokens de autenticación.
# Requerido por: kin-backend (application.yml), docker-compose.yml
# Valor para local: el que uses en tu entorno de desarrollo
JWT_SECRET=your_jwt_secret_here

# PostgreSQL — Contraseña de la base de datos (solo Docker).
# Requerido por: docker-compose.yml (raíz), kin-database/docker-compose.yml
POSTGRES_PASSWORD=your_postgres_password_here

# DeepSeek API — Clave para el chat con IA (Ollama es el default en dev).
# Requerido por: kin-backend (AiEngineService)
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# ============================================================
# PRODUCCIÓN (Render) — Base de datos PostgreSQL
# ============================================================
# DATABASE_URL=postgresql://user:pass@host:5432/kin_platform
# DATABASE_USER=kin_admin
# DATABASE_PASSWORD=your_db_password_here
# PORT=8080
